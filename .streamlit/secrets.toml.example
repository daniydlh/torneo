# Copia este archivo a .streamlit/secrets.toml y rellena tus credenciales reales.
# .streamlit/secrets.toml NUNCA debe subirse a un repositorio público.

SUPABASE_URL = "https://xxxxxxxxxxxx.supabase.co"
SUPABASE_KEY = "tu-clave-anon-public-de-supabase"

CLOUDINARY_CLOUD_NAME = "tu-cloud-name"
CLOUDINARY_API_KEY = "tu-api-key"
CLOUDINARY_API_SECRET = "tu-api-secret"

ADMIN_PASSWORD = "elige-una-contraseña-segura"
